From: poeggi <48416618+poeggi@users.noreply.github.com>
Date: Fri, 12 Jun 2026 16:56:47 +0800
Subject: [PATCH 09/12] refactor: drop mac_ok variable, inline condition

---
 wsd_simple_server.c | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/wsd_simple_server.c b/wsd_simple_server.c
index c638666..6dcea1b 100644
--- a/wsd_simple_server.c
+++ b/wsd_simple_server.c
@@ -635,9 +635,8 @@ int main(int argc, char **argv)
     /* ---- Stable UUID from MAC (WS-Discovery 1.1 EPR stability req.) ---- */
     {
         uint8_t mac[6] = {0};
-        int mac_ok = (if_name ? get_mac_by_ifname(if_name, mac)
-                              : get_mac_by_ip(address, mac)) == 0;
-        if (!mac_ok) {
+        if ((if_name ? get_mac_by_ifname(if_name, mac)
+                     : get_mac_by_ip(address, mac)) != 0) {
             log_fatal("Cannot get MAC address for interface -- cannot generate stable device UUID.");
             exit(EXIT_FAILURE);
         }
