 conf.c                           |  81 ++++++++++++++++---
 device_service.c                 |  44 +++-------
 events_service.c                 |  10 +--
 fault.c                          |   8 +-
 media2_service.c                 |  16 +---
 media_service.c                  |  16 +---
 onvif_simple_server.conf.example |   2 +-
 onvif_simple_server.h            |   4 +-
 onvif_simple_server.json.example |   1 -
 utils.c                          | 133 +++++++++++++++++++++++++++++++
 utils.h                          |   3 +
 12 files changed, 234 insertions(+), 88 deletions(-)

