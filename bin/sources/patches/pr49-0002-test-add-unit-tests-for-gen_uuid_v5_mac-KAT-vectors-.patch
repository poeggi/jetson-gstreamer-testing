 test/mbedtls/sha1.h   |  14 +++++
 test/stubs.c          |  20 ++++++
 test/test_utils.c     | 139 ++++++++++++++++++++++++++++++++++++++++++
 4 files changed, 184 insertions(+)
 create mode 100644 test/mbedtls/base64.h
 create mode 100644 test/mbedtls/sha1.h
 create mode 100644 test/stubs.c
 create mode 100644 test/test_utils.c

